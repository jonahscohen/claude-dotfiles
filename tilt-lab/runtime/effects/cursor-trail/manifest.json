{
  "id": "cursor-trail",
  "name": "Cursor Image Trail",
  "category": "pointer",
  "layerRole": "pointer",
  "params": [
    {
      "name": "preset",
      "type": "select",
      "default": "Classic",
      "options": ["Classic", "Subtle", "Wild", "Dense", "Slow Fade"]
    },
    { "name": "itemSize", "type": "range", "default": 120, "min": 20, "max": 400, "step": 1 },
    { "name": "trailLength", "type": "range", "default": 8, "min": 1, "max": 24, "step": 1 },
    { "name": "spawnDistance", "type": "range", "default": 80, "min": 10, "max": 300, "step": 1 },
    { "name": "rotationRange", "type": "range", "default": 20, "min": 0, "max": 90, "step": 1 },
    { "name": "fadeDuration", "type": "range", "default": 400, "min": 100, "max": 1500, "step": 10 },
    { "name": "exitBlur", "type": "range", "default": 4, "min": 0, "max": 20, "step": 0.5 },
    { "name": "enterScale", "type": "range", "default": 0.5, "min": 0.1, "max": 1.5, "step": 0.05 },
    { "name": "exitScale", "type": "range", "default": 0.3, "min": 0.1, "max": 1, "step": 0.05 },
    { "name": "scaleFloor", "type": "range", "default": 0.6, "min": 0.1, "max": 1, "step": 0.05 },
    { "name": "enterRotateMult", "type": "range", "default": 1.5, "min": 0, "max": 3, "step": 0.1 },
    { "name": "exitRotateMult", "type": "range", "default": 0.5, "min": 0, "max": 2, "step": 0.1 },
    {
      "name": "easing",
      "type": "select",
      "default": "expoOut",
      "options": ["expoOut", "easeOut", "linear", "backOut", "circOut"]
    },
    { "name": "wipeOnLeave", "type": "toggle", "default": true }
  ],
  "requiredAssets": ["item1", "item2"],
  "origin": "https://ui.unlumen.com/components/cursor-image-trail",
  "license": "unstated (recreated-from-existing-work disclaimer)",
  "attribution": "unlumen / Leo (ui.unlumen.com)",
  "redistribution": "personal-only",
  "tags": ["cursor", "pointer", "trail", "images", "dom", "framer-motion", "motion", "presets", "overlay"]
}
