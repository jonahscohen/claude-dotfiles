{
  "id": "ascii",
  "name": "ASCII",
  "category": "post-process",
  "layerRole": "post",
  "params": [
    { "name": "renderMode", "type": "select", "default": "characters", "options": ["characters", "block-chars", "lines", "diagonal", "cross", "diamond", "mixed", "dots", "pixel", "lego", "mosaic", "braille", "3d", "disco", "shapes"] },
    { "name": "charSet", "type": "select", "default": "standard", "options": ["standard", "detailed", "minimal", "blocks"] },
    { "name": "customChars", "type": "text", "default": "", "placeholder": "@#S08Xx+=-;:,.  (custom ramp, bright -> dark)", "maxLength": 256 },
    { "name": "fontSize", "type": "range", "default": 11, "min": 4, "max": 40, "step": 1 },
    { "name": "coverage", "type": "range", "default": 85, "min": 0, "max": 100, "step": 1 },
    { "name": "edgeEmphasis", "type": "range", "default": 60, "min": 0, "max": 100, "step": 1 },
    { "name": "darkThreshold", "type": "range", "default": 30, "min": 0, "max": 100, "step": 1 },
    { "name": "brightness", "type": "range", "default": 0, "min": -100, "max": 100, "step": 1 },
    { "name": "contrast", "type": "range", "default": 100, "min": 0, "max": 255, "step": 1 },
    { "name": "invert", "type": "toggle", "default": false },
    { "name": "randomChars", "type": "toggle", "default": false },
    { "name": "charOpacity", "type": "range", "default": 100, "min": 0, "max": 100, "step": 1 },
    { "name": "mosaicShape", "type": "select", "default": "square", "options": ["square", "circle"] },
    { "name": "bgMode", "type": "select", "default": "blur", "options": ["solid", "none", "blur"] },
    { "name": "bgBlur", "type": "range", "default": 8, "min": 0, "max": 30, "step": 1 },
    { "name": "bgOpacity", "type": "range", "default": 90, "min": 0, "max": 100, "step": 1 },
    { "name": "dotGrid", "type": "toggle", "default": false },
    { "name": "blendMode", "type": "select", "default": "source-over", "options": ["source-over", "multiply", "screen", "overlay", "lighten", "darken", "color-dodge", "color-burn"] },
    { "name": "overlayColor", "type": "color", "default": "#ff0000" },
    { "name": "overlayOpacity", "type": "range", "default": 0, "min": 0, "max": 100, "step": 1 },
    { "name": "overlayBlend", "type": "select", "default": "multiply", "options": ["source-over", "multiply", "screen", "overlay", "lighten", "darken", "color-dodge", "color-burn"] },
    { "name": "shape3dCellSize", "type": "range", "default": 12, "min": 4, "max": 60, "step": 1 },
    { "name": "shape3dHSpacing", "type": "range", "default": 100, "min": 50, "max": 200, "step": 1 },
    { "name": "shape3dVSpacing", "type": "range", "default": 100, "min": 50, "max": 200, "step": 1 },
    { "name": "shape3dTopShade", "type": "range", "default": 135, "min": 0, "max": 200, "step": 1 },
    { "name": "shape3dLightShade", "type": "range", "default": 100, "min": 0, "max": 200, "step": 1 },
    { "name": "shape3dDarkShade", "type": "range", "default": 55, "min": 0, "max": 200, "step": 1 },
    { "name": "shape3dOutline", "type": "range", "default": 0, "min": 0, "max": 5, "step": 0.5 },
    { "name": "shape3dFlip", "type": "toggle", "default": false },
    { "name": "discoUniformity", "type": "range", "default": 80, "min": 0, "max": 100, "step": 1 },
    { "name": "discoSeed", "type": "range", "default": 1, "min": 1, "max": 100, "step": 1 },
    { "name": "colorMode", "type": "select", "default": "sampled", "options": ["sampled", "mono", "palette"] },
    { "name": "monoColor", "type": "color", "default": "#ffffff" },
    { "name": "jitter", "type": "range", "default": 30, "min": 0, "max": 100, "step": 1 },
    { "name": "threshold", "type": "range", "default": 50, "min": 0, "max": 100, "step": 1 },
    { "name": "posterize", "type": "range", "default": 4, "min": 2, "max": 8, "step": 1 },
    { "name": "animated", "type": "toggle", "default": false },
    { "name": "animStyle", "type": "select", "default": "wave", "options": ["wave", "cascade", "reveal", "pulse"] },
    { "name": "animSpeed", "type": "range", "default": 3, "min": 0.25, "max": 10, "step": 0.25 },
    { "name": "animIntensity", "type": "range", "default": 60, "min": 0, "max": 100, "step": 1 },
    { "name": "animRandomness", "type": "range", "default": 50, "min": 0, "max": 100, "step": 1 },
    { "name": "fxVignette", "type": "toggle", "default": false },
    { "name": "fxScanLines", "type": "toggle", "default": false },
    { "name": "fxCRT", "type": "toggle", "default": false },
    { "name": "fxChromatic", "type": "toggle", "default": false },
    { "name": "fxBloom", "type": "toggle", "default": false },
    { "name": "fxFilmGrain", "type": "toggle", "default": false },
    { "name": "fxGlitch", "type": "toggle", "default": false },
    { "name": "fxRGBSplit", "type": "toggle", "default": false },
    { "name": "fxBlur", "type": "toggle", "default": false },
    { "name": "fxPixelate", "type": "toggle", "default": false },
    { "name": "fxHalftone", "type": "toggle", "default": false },
    { "name": "fxFilmDust", "type": "toggle", "default": false },
    { "name": "lightMode", "type": "toggle", "default": false }
  ],
  "requiredAssets": [],
  "origin": "https://ascii-magic.com/app",
  "license": "proprietary (all rights reserved); algorithm reimplemented clean",
  "attribution": "ascii-magic",
  "redistribution": "reimplemented",
  "tags": ["canvas2d", "ascii", "post-process", "halftone", "luminance", "sobel", "text", "dither"]
}
