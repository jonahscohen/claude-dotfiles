    { "name": "scale", "type": "range", "default": 1, "min": 0.1, "max": 4, "step": 0.01 },
    { "name": "offsetX", "type": "range", "default": 0, "min": -1, "max": 1, "step": 0.01 },
    { "name": "offsetY", "type": "range", "default": 0, "min": -1, "max": 1, "step": 0.01 },
    { "name": "rotation", "type": "range", "default": 0, "min": -180, "max": 180, "step": 1 },
