{
  "env": {
    "CLAUDE_CODE_NO_FLICKER": "1"
  },
  "permissions": {
    "allow": [
      "Bash(npx create-next-app@latest:*)",
      "Bash(claude mcp:*)",
      "Write(**/*.md)",
      "Edit(**/*.md)",
      "MultiEdit(**/*.md)",
      "Write(**/.claude/memory/**)",
      "Edit(**/.claude/memory/**)",
      "MultiEdit(**/.claude/memory/**)",
      "Write(/Users/*/.claude/projects/**/memory/**)",
      "Edit(/Users/*/.claude/projects/**/memory/**)",
      "MultiEdit(/Users/*/.claude/projects/**/memory/**)",
      "Write(/Users/**/memory/**)",
      "Edit(/Users/**/memory/**)",
      "MultiEdit(/Users/**/memory/**)",
      "Write(/home/**/memory/**)",
      "Edit(/home/**/memory/**)",
      "MultiEdit(/home/**/memory/**)",
      "Write(**/memory/**)",
      "Edit(**/memory/**)",
      "MultiEdit(**/memory/**)",
      "Write(**/MEMORY.md)",
      "Edit(**/MEMORY.md)",
      "MultiEdit(**/MEMORY.md)",
      "Write(.claude/memory/**)",
      "Edit(.claude/memory/**)",
      "MultiEdit(.claude/memory/**)",
      "Write(~/.claude/projects/**/memory/**)",
      "Edit(~/.claude/projects/**/memory/**)",
      "MultiEdit(~/.claude/projects/**/memory/**)",
      "mcp__pencil"
    ],
    "defaultMode": "bypassPermissions"
  },
  "model": "claude-opus-4-6[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/bash-guard.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/memory-approve.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/content-guard.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "SESSION_CWD=\"$(pwd)\" ~/.claude/startup-check.sh",
            "timeout": 10,
            "statusMessage": "Loading memory..."
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "printf '%s' '{\"systemMessage\":\"PreCompact: flushing pending memory\",\"hookSpecificOutput\":{\"hookEventName\":\"PreCompact\",\"additionalContext\":\"PRE-COMPACT: Before this context compresses, write any pending session memory entries to .claude/memory/ per CLAUDE.md memory discipline. Do this NOW.\"}}'",
            "timeout": 5,
            "statusMessage": "Flushing memory before compact..."
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "SESSION_CWD=\"$(pwd)\" ~/.claude/startup-check.sh",
            "timeout": 10,
            "statusMessage": "Reloading memory after compaction..."
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "[ -x ~/.claude/statusline-command.sh ] && bash ~/.claude/statusline-command.sh || true"
  },
  "enabledPlugins": {
    "claude-md-management@claude-plugins-official": true,
    "figma@claude-plugins-official": true,
    "firebase@claude-plugins-official": true,
    "github@claude-plugins-official": false,
    "hookify@claude-plugins-official": true,
    "learning-output-style@claude-plugins-official": false,
    "semgrep@claude-plugins-official": false,
    "skill-creator@claude-plugins-official": true,
    "sentry@claude-plugins-official": true,
    "supabase@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "agent-sdk-dev@claude-plugins-official": true,
    "vercel@claude-plugins-official": false,
    "typescript-lsp@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "discord@claude-plugins-official": true,
    "impeccable@impeccable": true
  },
  "extraKnownMarketplaces": {
    "impeccable": {
      "source": {
        "source": "github",
        "repo": "pbakaus/impeccable"
      },
      "autoUpdate": true
    }
  },
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "verbose": true
}