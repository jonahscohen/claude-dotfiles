  "aiSlopDetection": {
    "genericityScore": {
      "description": "0-100 scale where 0=unique, 100=generic",
      "thresholds": {
        "exclude": ">70 (unless user overrides)",
        "caution": "55-70 (reviewable)",
        "good": "<55 (acceptable)"
      }
    },
    "patternTypes": {
      "color_palette": {
        "generic_indicators": [
          "Exact match to Material Design colors",
          "Exact match to TailwindCSS default palette",
          "Pure grays without chroma shift",
          "Standard primary-blue, secondary-purple, accent-orange"
        ],
        "uniqueness_indicators": [
          "Custom hex values",
          "Tinted neutrals (chroma 0.005-0.01)",
          "Brand-specific color story",
          "Domain-specific palette (e.g. healthcare blues, legal purples)"
        ],
        "scoringRule": "Count generic indicators vs uniqueness indicators"
      },
      "typography": {
        "generic_indicators": [
          "Only Google Fonts defaults (Inter, Roboto, Lato)",
          "Standard size scale without custom ratios",
          "No custom letter spacing or line heights"
        ],
        "uniqueness_indicators": [
          "Unique font pairing strategy",
          "Custom optical sizing",
          "Specific line height ratios tied to brand"
        ]
      },
      "spatial_system": {
        "generic_indicators": [
          "Exact 8pt or 4pt system with no customization",
          "Gaps match default design tool spacing"
        ],
        "uniqueness_indicators": [
          "Custom modular scale (e.g. 1.25 ratio)",
          "Spacing tied to content rhythm",
          "Asymmetric spacing strategy"
        ]
      }
    }
  },
