  "curation": {
    "command": "/curate",
    "workflow": [
      {
        "step": 1,
        "action": "User provides design screenshot or component image",
        "input": "image/png, image/jpeg"
      },
      {
        "step": 2,
        "action": "Claude vision API analyzes image",
        "detects": [
          "Color palette (extracts hex codes)",
          "Spatial rhythm (grid size inference)",
          "Typography (font sizes, weights, line-heights)",
          "Component states (detects 8 states visually)",
          "Interaction patterns"
        ]
      },
      {
        "step": 3,
        "action": "Store captured assets",
        "location": "user-captured/<date>/",
        "structure": {
          "colors.json": "Extracted color hex + semantic names",
          "spacing.json": "Detected grid + gaps",
          "typography.json": "Font metrics",
          "components.json": "Component variants + states"
        }
      },
      {
        "step": 4,
        "action": "Generate DESIGN.md snippet",
        "output": "Auto-populated tokens ready for copy-paste"
      },
      {
        "step": 5,
        "action": "Update design-references.json",
        "adds": "New pattern to future reference database"
      }
    ]
  },
  "antiPatterns": [
    {
      "pattern": "Exact Material Design colors",
