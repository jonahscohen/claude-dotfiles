  "iconExample": {
    "id": "chevron-right",
    "name": "Chevron Right",
    "category": "navigation",
    "description": "Right-pointing chevron for navigation or list continuation",
    "sources": {
      "heroicons": {
        "outline": "M9 5l7 7-7 7",
        "solid": "M9 5l7 7-7 7"
      },
      "lucide": {
        "default": "M9 6l6 6-6 6"
      },
      "tabler": {
        "outline": "M9 6l6 6-6 6",
        "filled": "M9 6l6 6-6 6"
      }
    },
    "sizeVariants": {
      "20": "SVG path optimized for 20px",
      "24": "SVG path optimized for 24px",
      "32": "SVG path optimized for 32px"
    },
    "usage": "Navigation lists, pagination next button, dropdown indicators",
    "accessibility": {
      "decorative": "aria-hidden='true' (when purely decorative)",
      "functional": "aria-label='Next' (when indicating action)"
    },
    "fillGuidance": {
      "onLight": "color: currentColor or #333",
      "onDark": "color: currentColor or #fff",
      "contrast": "AA compliant (4.5:1 minimum)"
    },
    "sizeGuidance": {
      "16px": "Inline icons within text",
      "20px": "Form controls, small buttons",
      "24px": "Standard icon buttons (44x44px minimum)",
      "32px": "Large navigation, hero sections",
      "48px+": "Display, oversized accent icons"
    }
  },
  "accessibility": {
    "decorativeIcons": {
      "rule": "Use aria-hidden='true' when icon is purely decorative",
      "example": "Chevron next to text 'Next' button"
    },
    "functionalIcons": {
      "rule": "Use aria-label when icon conveys meaning",
      "example": "<button aria-label='Delete'><TrashIcon/></button>"
    },
    "colorContrast": {
      "rule": "Icon colors must meet WCAG AA (4.5:1 on backgrounds)",
      "tip": "Use currentColor to inherit from text color"
    }
  },
  "usage": [
    {
      "context": "Navigation item",
      "size": "24px",
      "variant": "outline or default",
      "example": "<NavLink><HomeIcon/> Home</NavLink>"
    },
    {
      "context": "Form field indicator",
      "size": "20px",
      "variant": "solid or filled",
      "example": "<input/><CheckIcon/>"
    },
    {
      "context": "Button icon",
      "size": "20-24px",
      "variant": "outline or default",
      "example": "<button><SaveIcon/> Save</button>"
    },
    {
      "context": "Status indicator",
      "size": "16-20px",
      "variant": "solid or filled",
      "colors": ["success-green", "error-red", "warning-yellow"],
      "example": "<StatusIcon color='green'/>"
    }
  ],
  "colorGuidance": [
    {
      "scenario": "Icon on light background",
      "color": "currentColor or #333",
      "contrast": "13:1 (AAA)"
    },
    {
      "scenario": "Icon on dark background",
      "color": "currentColor or #fff",
      "contrast": "14:1 (AAA)"
    },
    {
      "scenario": "Icon on primary-color background",
      "color": "white",
      "contrast": "Verify WCAG AA minimum"
    },
    {
      "scenario": "Icon next to text",
      "color": "Match text color",
      "contrast": "Inherit from text"
    }
  ],
  "antiPatterns": [
    {
      "pattern": "Using icons without labels",
      "impact": "Unclear meaning, accessibility failure",
      "fix": "Add aria-label or visible label text"
    },
    {
      "pattern": "Icons too small (<16px) in interactive contexts",
      "impact": "Hard to click, accessibility failure",
      "fix": "Use minimum 20px, button minimum 44x44px total"
    },
    {
      "pattern": "Icon colors not contrasting with background",
      "impact": "Fails WCAG AA (4.5:1), hard to see",
      "fix": "Verify contrast ratio, use darker/lighter color"
    },
    {
      "pattern": "Mismatched icon styles (mixing outline + solid inconsistently)",
      "impact": "Visual inconsistency",
      "fix": "Use consistent variant throughout app"
    }
  ],
